# Serper API
SERPER_API_KEY=your_serper_api_key_here

# Database
# Local PostgreSQL
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/erli_db

# Supabase PostgreSQL (використовуй порт пулера 6543 для serverless/Edge deployment)
DATABASE_URL=postgresql+asyncpg://postgres.your_project_ref:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# AI Models
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Business Logic (Default values shown)
# SCRAPE_INTERVAL_HOURS=4
# PRICE_CHANGE_THRESHOLD_PERCENT=5.0
